{
  "name": "babylonjs-sample-app",
  "version": "1.0.0",
  "description": "A simple 3D application using Babylon.js",
  "main": "dist/app.js",
  "scripts": {
    "build": "npx esbuild src/app.ts --bundle --outfile=dist/app.js",
    "start": "npx esbuild src/app.ts --bundle --outfile=dist/app.js && npx http-server -c-1 -p 8080",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom"
  },
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@babylonjs/core": "^7.13.1",
    "babylonjs": "^7.13.1"
  },
  "devDependencies": {
    "@types/babylonjs": "^2.4.1",
    "@types/jest": "^30.0.0",
    "esbuild": "^0.27.4",
    "http-server": "^14.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.5.3"
  }
}
